# INSAT Scheduler — Configuration Template
# Copy this file and set variables in your shell before running swipl.
#
# Windows PowerShell:
#   $env:SCHED_SCENARIO = "demo"
#   swipl main.pl
#
# Linux / macOS:
#   SCHED_SCENARIO=demo swipl main.pl

# Scenario to run.
# Options: demo | gl3_only | engineering | full_campus
SCHED_SCENARIO=demo

# Maximum number of valid schedules to collect.
# 1 = first-valid mode (fastest).
SCHED_LIMIT=1

# Optimisation mode applied when comparing schedules.
# Options: none | energy | balanced
SCHED_OPT=none

# Enforce building-level daily energy thresholds during generation.
# Set to false to skip energy checks (faster, more solutions).
SCHED_ENERGY=true
